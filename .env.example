
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgres://your_username:your_password@localhost:5432/your_database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_key
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=secret_id
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
MOBILE_APP_DEEP_LINK=appname://auth/callback

# MQTT Broker
MQTT_BROKER_URL=mqtt://your-broker.com
MQTT_PORT=1883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password
MQTT_CLIENT_ID=express-api-client